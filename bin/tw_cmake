#!/bin/bash
#
# tool to generate CMakeLists.txt for teeworlds and ddnet
# it looks at the src directory and inserts the sorted list
# in CMakeLists.txt
#
# USAGE
# navigate to the root of the teeworlds or ddnet repository
# and then execute:
# tw_cmake .

set -u

if [ "$#" -ne "1" ]
then
	echo "Usage: $(basename "$0") [COMMAND] <teeworlds source root>"
	echo "Commands:"
	echo "  clean - delete all cmake build cache"
	exit 1
fi
TWPATH="$1"
BASE_CMAKELISTS="$TWPATH/"CMakeLists.txt

if [ ! -d "$TWPATH" ]
then
	if [ "$TWPATH" == "clean" ]
	then
		if [ -f Makefile ] && [ -d ../.git ] && [ "$(basename "$(pwd)")" == "build" ]
		then
			echo "[*] Cleaning current build directory ..."
			rm -rf Makefile CMakeFiles src
			exit 0
		fi
		echo "[*] Already clean or not a build directory."
		exit 1
	fi
	echo "[-] Error: teeworlds path '$TWPATH' is invalid"
	exit 1
fi

if [ ! -f "$BASE_CMAKELISTS" ]
then
	echo "[-] Error: '$BASE_CMAKELISTS' file not found."
	exit 1
fi

function generate_data() {
	local cmake_file="$1"
	local f
	local files
	if ! grep -q EXPECTED_DATA "$cmake_file"
	then
		echo "[!] Warning: not EXPECTED_DATA entry found"
		return
	fi

	local expected_data_line
	if ! expected_data_line="$(grep '^set_glob.*EXPECTED_DATA' "$cmake_file")"
	then
		echo "[!] Warning: did not match EXPECTED_DATA line"
		return
	fi

	if [ "$(echo "$expected_data_line" | wc -l)" -gt "1" ]
	then
		echo "[!] Warning: found multiple EXPECTED_DATA lines. Skipping data folder!"
		echo "             lines found:"
		echo ""
		echo "$expected_data_line"
		echo ""
		return
	fi

	# expected_data_line is supposed to look like one of these:
	#
	# set_glob(DATA GLOB_RECURSE "png;map" data ${EXPECTED_DATA})
	# set_glob(DATA GLOB_RECURSE "json;map;png;rules;ttc;ttf;txt;wv" datasrc ${EXPECTED_DATA})
	# set_glob(DATA GLOB_RECURSE "cfg;frag;json;map;otf;png;rules;ttc;ttf;txt;vert;wv" data ${EXPECTED_DATA})
	#
	# which means we could also verify we search for the correct file extensions

	local datasrc_path="$TWPATH/datasrc"
	if printf "%s" "$expected_data_line" | grep -q " data "
	then
		# assume datasrc by default
		# if we match " data " it is probably data
		datasrc_path="$TWPATH/data"

		if printf "%s" "$expected_data_line" | grep -q " datasrc "
		then
			echo "[!] Warning: can not determine data folder location"
			echo "             found both 'data' and 'datasrc' in this line"
			echo ""
			echo "$expected_data_line"
			echo ""
			return
		fi

		echo "[*] use data/ dir instead of datasrc/"
	fi

	if [ ! -d "$datasrc_path" ]
	then
		echo "[-] Error: '$datasrc_path' path not found."
		exit 1
	fi

	local tidy_comments=0
	if grep -qF "# tidy-alphabetical-start" "$cmake_file"
	then
		tidy_comments=1
	fi

	local indent="  "

	files=$(find "$datasrc_path" -type f \( \
		-name "*.cfg" 	-o \
		-name "*.frag" 	-o \
		-name "*.json" 	-o \
		-name "*.map" 	-o \
		-name "*.otf" 	-o \
		-name "*.pem" 	-o \
		-name "*.png" 	-o \
		-name "*.rules"	-o \
		-name "*.txt"	-o \
		-name "*.ttf" 	-o \
		-name "*.ttc" 	-o \
		-name "*.vert" 	-o \
		-name "*.wv" \) -print0 | while IFS= read -r -d '' f
	do
		f="${f// /\\ }"
		echo "$indent${f/$datasrc_path\//}"
	done | LC_ALL=C sort)

	pad="########################################################################"
	empty=$(sed '/set(EXPECTED_DATA/,/)/d' "$cmake_file" | \
		tr '\n' '\f' | \
		sed -e "s/# DATA\\f$pad/# DATA\\f$pad\\fXXX START\\fXXX END/" | \
		tr '\f' '\n')
	{
		echo "$empty" | sed -n -e '/XXX START/,$!p'
		echo ""
		echo "set(EXPECTED_DATA"
		[[ "$tidy_comments" = 1 ]] && printf -- '%s# tidy-alphabetical-start\n' "$indent"
		echo "$files"
		[[ "$tidy_comments" = 1 ]] && printf -- '%s# tidy-alphabetical-end\n' "$indent"
		printf ")"
		echo "$empty" | sed -n -e '1,/XXX END/!p'
	} > "$cmake_file"
}

function get_files_recurse() {
	local dir="$1"
	local oneline="$2"
	local indent="${3:-  }"
	local strip_dir="${4:-1}"
	local pipe=cat
	dir="$TWPATH/$dir"
	if [ "$oneline" == "1" ]
	then
		pipe="tr '\n' ' '"
	fi
	find -L "$dir" -type f \( \
		-name "*.cpp" -o \
		-name "*.c" -o \
		-name "*.h" \) -print0 | while IFS= read -r -d '' f
	do
		f="${f// /\\ }"
		if [ "$strip_dir" == "1" ]
		then
			f="${f/$dir\//}"
		else
			# cut the leading ./ from find
			f="${f:2}"
		fi
		if [ "$oneline" == "1" ]
		then
			printf "\n%s" "$f"
		else
			printf "%s%s\n" "$indent" "$f"
		fi
	done | LC_ALL=C sort | eval "$pipe"
}

function get_files() {
	local dir="$1"
	local oneline="$2"
	local indent="${3:-  }"
	local pipe=cat
	dir="$TWPATH/$dir"
	if [ "$oneline" == "1" ]
	then
		pipe="tr '\n' ' '"
	fi
	find "$dir" \
		-maxdepth 1 \
		-type f \( \
		-name "*.cpp" -o \
		-name "*.c" -o \
		-name "*.h" \) -print0 | while IFS= read -r -d '' f
	do
		f="${f// /\\ }"
		if [ "$oneline" == "1" ]
		then
			printf "\n%s" "${f/$dir\//}"
		else
			printf "%s%s\n" "$indent" "${f/$dir\//}"
		fi
	done | LC_ALL=C sort | eval "$pipe"
}

function generate_src_oneline() {
	local cmake_file="$1"
	local set_str="$2"
	local dir="$3"
	local files
	local set_str_start
	files="$(get_files_recurse "$dir" 1)"
	files="${files::-1}"
	set_str_start="$(echo "$set_src" | cut -d' ' -f1-3)"
	while IFS= read -r line
	do
		if [ "$line" == "$set_src" ]
		then
			printf "%s%s)\n" "$set_str_start" "$files"
		else
			echo "$line"
		fi
	done < "$cmake_file" > "${cmake_file}.tmp"
	mv "${cmake_file}.tmp" "$cmake_file"
}

function generate_src() {
	local cmake_file="$1"
	local set_str="$2"
	local dir="$3"
	local recurse="${4:-1}"
	local tidy_comments="${5:-0}"
	local line
	local is_match=0
	local indent
	echo "[*] generate source $set_src ..."
	while IFS= read -r line
	do
		if [ "$is_match" == "0" ]
		then
			if [ "$line" == "$set_str" ]
			then
				is_match=1
			fi
			echo "$line"
			indent=''
		else
			if [ "$indent" == "" ]
			then
				indent="$(echo "$line" | grep -o '^[[:space:]]*')"
			fi
			if [[ "$line" =~ ^[[:space:]]*\) ]]
			then
				is_match=0
				[[ "$tidy_comments" = 1 ]] && printf -- '%s# tidy-alphabetical-start\n' "$indent"
				if [ "$recurse" == "1" ]
				then
					get_files_recurse "$dir" "0" "$indent"
				else
					get_files "$dir" "0" "$indent"
				fi
				[[ "$tidy_comments" = 1 ]] && printf -- '%s# tidy-alphabetical-end\n' "$indent"
				printf -- '%s\n' "$line"
			fi
		fi
	done < "$cmake_file" > "${cmake_file}.tmp"
	mv "${cmake_file}.tmp" "$cmake_file"
}

function generate_sources() {
	local cmake_file="$1"
	local set_src
	local recurse
	local tidy_comments=0
	if grep -qF "# tidy-alphabetical-start" "$cmake_file"
	then
		echo "[*] detected tidy alphabetical comments"
		tidy_comments=1
	fi

	while IFS= read -r set_src
	do
		if \
			[[ "$set_src" == *MASTERSRV_SRC* ]] || \
			[[ "$set_src" == *TWPING_SRC* ]]
		then
					continue
		fi
		# only care about old 0.6.5 set_glob
		# ignore the new set_glob
		# old:
		# set_glob(DEP_MD5_SRC GLOB src/engine/external/md5 md5.c md5.h)
		# new:
		# set_glob(DATA GLOB_RECURSE "json;map;png;rules;ttc;ttf;txt;wv" datasrc ${EXPECTED_DATA})
		if [[ "$set_src" =~ ^[[:space:]]*set_glob.* ]]
		then
			if [[ ! "$set_src" =~ set_glob\([A-Z0-9_]+\ GLOB(_RECURSE)?\ src ]]
			then
				# did not detect old set_glob that has the same format
				# as set_src
				# -> assuming new glob and ignore it
				continue
			fi
		fi
		if [[ "$set_src" =~ \) ]]
		then
			generate_src_oneline "$cmake_file" "$set_src" "$(echo "$set_src" | awk '{ print $3 }')"
		else
			if echo "$set_src" | grep -q GLOB_RECURSE
			then
				recurse=1
			else
				recurse=0
			fi
			generate_src "$cmake_file" "$set_src" "$(echo "$set_src" | awk '{ print $3 }')" "$recurse" "$tidy_comments"
		fi
	done < <(grep -E '^[[:space:]]*set_(src|glob)\(' "$cmake_file")
}

patch_cmake_ddnet_base_lib() {
	local cmake_file="$BASE_CMAKELISTS"
	local set_src
	local recurse=1
	local tidy_comments=0
	local is_match=0
	local dir=src

	get_lib_headers() {
		local indent=$'\t'
		find -L ./src -type f \( \
		-name "*.h" \) -print0 | while IFS= read -r -d '' f
		do
				[[ "$f" = *"/external/"* ]] && continue

				f="${f// /\\ }"
				# cut the leading ./ from find
				f="${f:2}"
				printf "%s%s\n" "$indent" "$f"
			done | LC_ALL=C sort
	}

	while IFS= read -r line
	do
		if [ "$is_match" == "0" ]
		then
			if [ "$line" == "set(LIB_PUBLIC_HEADERS_BASE" ]
			then
				is_match=1
			fi
			echo "$line"
			indent=''
		else
			if [ "$indent" == "" ]
			then
				indent="$(echo "$line" | grep -o '^[[:space:]]*')"
			fi
			if [[ "$line" =~ ^[[:space:]]*\) ]]
			then
				is_match=0
				get_lib_headers
				printf -- '%s\n' "$line"
			fi
		fi
	done < "$cmake_file" > "${cmake_file}.tmp"
	mv "${cmake_file}.tmp" "$cmake_file"
}

patch_cmake_ddnet_or_teeworlds() {
	generate_data "$BASE_CMAKELISTS"
	generate_sources "$BASE_CMAKELISTS"

	for insta_fork_list in "$TWPATH"/src/*/CMakeLists.txt
	do
		if [ -f "$insta_fork_list" ]
		then
			# ddnet-insta has a extra CMakeLists.txt file for its files
			# https://github.com/ddnet-insta/ddnet-insta/blob/60764a877c09d57fbc6c8c2019f30f9b94c80121/src/insta/CMakeLists.txt
			echo "[*] detected ddnet-insta code base .."
			generate_sources "$insta_fork_list"
		fi
	done
}

if [ -d "$TWPATH"/src/ddnet_base ]
then
	echo "[*] detected ddnet_base library"
	patch_cmake_ddnet_base_lib
else
	patch_cmake_ddnet_or_teeworlds
fi

echo "[*] done"

